{{ 'hero-text.css' | asset_url | stylesheet_tag }}

<style>
.section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top | times: 0.75 | round }}px;
  padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round }}px;
  background-color: {{ section.settings.bg_color }};
  color: {{ section.settings.section_text_color }};
  {% if section.settings.background_image %}
    background-image: url({{ section.settings.background_image | image_url: width: 1600 }});
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  {% endif %}
}

@media screen and (min-width: 750px) {
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
}


</style>

<div class="hero-image-text section-{{ section.id }}-padding">
  <div class="banner__media">
    {% if section.settings.banner_image %}
      <img src="{{ section.settings.banner_image | image_url: width: 2000 }}" alt="Desktop Banner" class="desktop-banner">
    {% endif %}
    {% if section.settings.banner_image_mobile %}
      <img src="{{ section.settings.banner_image_mobile | image_url: width: 800 }}" alt="Mobile Banner" class="mobile-banner">
    {% endif %}

<div class="hero-image-text__wrapper ">
   <div class="container">
    <div class="hero-image-text__content">
      {% if section.settings.top-content != blank %}
        <p class="hero-image-text__caption-top">{{ section.settings.top-content }}</p>
      {% endif %}

      {% if section.settings.show_border2 %}
        <span class="border-line" style="color: {{ section.settings.text_color }}!important;"></span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="hero-image-text__heading title">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.content != blank %}
        <div class="hero-image-text__paragraph">{{ section.settings.content }}</div>
      {% endif %}

      {% if section.settings.bottom-content != blank %}
        <div class="hero-image-text__paragraph-bottom">{{ section.settings.bottom-content }}</div>
      {% endif %}
    </div>
  </div>
</div></div></div>

<style>
  .hero-image-text .banner__media {
    position: relative;
    width: 100%;
    height: 100%;
  }
  .hero-image-text .banner__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .hero-image-text .banner__media .desktop-banner {
  display: block;
  height: auto;
}
  .hero-image-text  .banner__media .mobile-banner {
    display: none;
}
  .hero-image-text__wrapper {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 2;
  text-align: center;
  color: {{ section.settings.section_text_color }};
  padding: 1rem;
  width: 100%;
  max-width: 800px;
}
  @media screen and (max-width: 789px) {
    .hero-image-text .banner__media .mobile-banner {
        display: block;
    }
     .hero-image-text .banner__media .desktop-banner{
       display: none;
    }
}

</style>
{% schema %}
{
  "name": "Hero Image Text",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Desktop Banner Image"
    },
    {
      "type": "image_picker",
      "id": "banner_image_mobile",
      "label": "Mobile Banner Image"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Section Background Image"
    },
    {
      "type": "text",
      "id": "top-content",
      "label": "Top Caption"
    },
    {
      "type": "checkbox",
      "id": "show_border2",
      "label": "Show Top Caption Border Line",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    },
    {
      "type": "richtext",
      "id": "bottom-content",
      "label": "Bottom Content"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "section_text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Hero Image Text"
    }
  ]
}
{% endschema %}
