{% schema %}
{
  "name": "Custom Banner",
  "tag": "section",
  "class": "section custom-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Desktop Banner Image"
    },
    {
      "type": "image_picker",
      "id": "banner_image_mobile",
      "label": "Mobile Banner Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Heading Here"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "This is the banner subtext you can customize."
    },
    {
      "type": "url",
      "id": "button_primary_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "button_primary_label",
      "label": "Primary Button Label",
      "default": "Primary Button"
    },
    {
      "type": "url",
      "id": "button_secondary_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "text",
      "id": "button_secondary_label",
      "label": "Secondary Button Label",
      "default": "Secondary Button"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.5
    },
    {
      "type": "range",
      "id": "banner_height",
      "label": "Banner Height (px)",
      "min": 300,
      "max": 800,
      "step": 10,
      "default": 500
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Optional Video Embed URL"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Custom Banner"
    }
  ]
}
{% endschema %}

<style>
  .custom-banner {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custom-banner .banner__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .custom-banner .desktop-banner {
    display: block;
  }

  .custom-banner .mobile-banner {
    display: none;
  }

  @media (max-width: 767px) {
    .custom-banner .desktop-banner {
      display: none;
    }
    .custom-banner .mobile-banner {
      display: block;
    }
  }

  .custom-banner::after {
    content: "";
    position: absolute;
    inset: 0;
    background: black;
    opacity: {{ section.settings.overlay_opacity }};
    z-index: 1;
  }

  .custom-banner .banner__content {
    position: absolute;
    z-index: 2;
    padding: 20px;
    width: 100%;
    color: {{ section.settings.text_color }};
    display: flex;
    flex-direction: column;
    gap: 1rem;
    {% if section.settings.text_alignment == 'left' %}
      text-align: left;
      align-items: flex-start;
    {% elsif section.settings.text_alignment == 'right' %}
      text-align: right;
      align-items: flex-end;
    {% else %}
      text-align: center;
      align-items: center;
    {% endif %}
  }

  .custom-banner .banner__heading {
    font-size: 2.5rem;
    margin: 0;
  }

  .custom-banner .banner__text {
    font-size: 1.2rem;
  }

  .custom-banner .banner__buttons a {
    text-decoration: none;
    padding: 10px 20px;
    margin: 5px;
    display: inline-block;
    font-weight: bold;
    border-radius: 5px;
    transition: all 0.3s ease;
  }

  .button--primary {
    background-color: #007bff;
    color: white;
  }

  .button--secondary {
    background-color: transparent;
    border: 2px solid white;
    color: white;
  }

  @media (max-width: 768px) {
    .custom-banner .banner__heading {
      font-size: 1.8rem;
    }

    .custom-banner .banner__text {
      font-size: 1rem;
    }
  }
</style>

<div class="custom-banner" style="height: {{ section.settings.banner_height }}px;">
  <div class="banner__media">
    {% if section.settings.banner_image %}
      <img src="{{ section.settings.banner_image | image_url: width: 1500 }}" alt="Desktop Banner" class="desktop-banner">
    {% endif %}
    {% if section.settings.banner_image_mobile %}
      <img src="{{ section.settings.banner_image_mobile | image_url: width: 800 }}" alt="Mobile Banner" class="mobile-banner">
    {% endif %}
  </div>

  <div class="banner__content">
    {% if section.settings.heading %}
      <h2 class="banner__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subtext %}
      <div class="banner__text">{{ section.settings.subtext }}</div>
    {% endif %}

    {% if section.settings.video_url %}
      <div class="banner__video" style="width:100%; max-width: 640px;">
        <iframe width="100%" height="360" src="{{ section.settings.video_url }}" frameborder="0" allowfullscreen></iframe>
      </div>
    {% endif %}

    <div class="banner__buttons">
      {% if section.settings.button_primary_label != blank %}
        <a href="{{ section.settings.button_primary_link }}" class="button--primary">{{ section.settings.button_primary_label }}</a>
      {% endif %}
      {% if section.settings.button_secondary_label != blank %}
        <a href="{{ section.settings.button_secondary_link }}" class="button--secondary">{{ section.settings.button_secondary_label }}</a>
      {% endif %}
    </div>
  </div>
</div>
